{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Launch Server (nodemon)",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "dev"
      ],
      "cwd": "${workspaceFolder}/server",
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/server/.env",
      "skipFiles": [
        "<node_internals>/**"
      ]
    }
  ]
}